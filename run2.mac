# Macro file for the ion beam simulation
#
# To be run preferably in batch, without graphics:
# % ionBeamSim run2.mac
#
#/run/numberOfThreads 4
/run/initialize
#
/control/verbose 2
/run/verbose 2
#
# gamma 6 MeV to the direction (0.,0.,1.)
# 10000 events
#
/gun/particle gamma
/gun/energy 6 MeV
#
/run/printProgress 1000
/run/beamOn 10000
# 
# proton 210 MeV to the direction (0.,0.,1.)
# 10000 events
#
/gun/particle proton
/gun/energy 210 MeV
#
/run/beamOn 10000
